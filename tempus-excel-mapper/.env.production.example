# ── Production Environment ─────────────────────────────
NODE_ENV=production
PORT=3001

# DSGVO: Erlaubte CORS-Origins (kommasepariert)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Tempus API (optional – kann auch über UI konfiguriert werden)
TEMPUS_API_BASE_URL=https://your-tempus-instance.com
TEMPUS_API_KEY=

# Anthropic API (optional – kann auch über UI konfiguriert werden)
# WICHTIG: Daten werden anonymisiert vor der Übertragung
ANTHROPIC_API_KEY=

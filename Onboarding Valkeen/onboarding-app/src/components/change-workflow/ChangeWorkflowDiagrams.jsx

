function Kotter8() {
  const items = [
    'Dringlichkeit',
    'Führungsnetzwerk',
    'Vision',
    'Kommunika­tion',
    'Befähigung',
    'Quick Wins',
    'Vertiefung',
    'Verankerung',
  ];
  return (
    <SvgFramed title="Häufige Ursachen, wenn Transformation ins Stocken gerät." vb="0 0 480 236" height="15rem">
      <SvgDefs />
      <text
        x="240"
        y="28"
        textAnchor="middle"
        fill="var(--cw-text-secondary)"
        style={{ font: '600 13px system-ui,sans-serif' }}
      >
        Checkliste: typische Ursachen beim Stocken von Change‑Initiativen
      </text>
      <g>
        {items.map((txt, idx) => {
          const row = idx < 4 ? 0 : 1;
          const col = idx % 4;
          const x = 28 + col * 112;
          const y = row === 0 ? 48 : 140;
          return (
            <g key={txt}>
              <rect
                x={x}
                y={y}
                rx="14"
                width="103"
                height="72"
                fill="var(--cw-link-muted-bg)"
                stroke="var(--cw-accent-soft-border)"
              />
              <text x={x + 52} y={y + 32} textAnchor="middle" fill="var(--cw-accent-strong)" style={{ font: 'bold 13px system-ui,sans-serif' }}>
                {idx + 1}.
              </text>
              <text x={x + 52} y={row === 0 ? y + 50 : y + 50} textAnchor="middle" fill="var(--cw-text)" style={{ font: 'bold 11px system-ui,sans-serif' }}>
                {txt}
              </text>
            </g>
          );
        })}
      </g>
      <text
        x="240"
        y="226"
        textAnchor="middle"
        fill="var(--cw-text-muted)"
        style={{ font: '10px system-ui,sans-serif' }}
      >
        Angelehnt an Kotter‑Logik („Why change efforts fail“).
      </text>
    </SvgFramed>
  );
}

function PmCmRails() {
  return (
    <SvgFramed title="Parallele Stränge Projekt‑ und Changearbeit." vb="0 0 480 188" height="11.75rem">
      <SvgDefs />
      {[
        { y: 56, title: 'Projektleitung', milestones: ['Start', 'Plan', 'Gestalt.', 'Überg.', 'Betrieb'], color: '#0f172a' },
        {
          y: 124,
          title: 'Change',
          milestones: ['Sinn', 'Stakeh.', 'Aktivier.', 'Adoption', 'Kultur'],
          color: '#5b21b6',
        },
      ].map((lane) => (
        <g key={lane.title}>
          <text x="24" y={lane.y} fill="var(--cw-text)" style={{ font: '700 12px system-ui,sans-serif', letterSpacing: '0.04em' }}>
            {lane.title}
          </text>
          <path d={`M132 ${lane.y - 10} H460`} stroke="var(--cw-border-subtle)" strokeWidth="10" strokeLinecap="round" />
          <path d={`M132 ${lane.y - 10} H460`} stroke="url(#cw-diag-accent)" strokeOpacity={lane.title === 'Change' ? 0.5 : 0.15} strokeWidth="10" strokeLinecap="round" />
          {lane.milestones.map((m, i) => {
            const x = 132 + i * ((460 - 132) / (lane.milestones.length - 1));
            return (
              <g key={m}>
                <circle cx={x} cy={lane.y - 10} r="14" fill="var(--cw-card)" stroke={lane.color} strokeWidth={lane.title === 'Change' ? 2.25 : 1.75} />
                <circle cx={x} cy={lane.y - 10} r={lane.title === 'Change' ? 5 : 3.25} fill={lane.color} opacity={lane.title === 'Change' ? 0.92 : 0.55} />
                <text
                  x={x}
                  y={lane.y + 18}
                  textAnchor="middle"
                  fill="var(--cw-text-muted)"
                  style={{ font: '9.5px system-ui,sans-serif' }}
                >
                  {m}
                </text>
              </g>
            );
          })}
        </g>
      ))}
    </SvgFramed>
  );
}


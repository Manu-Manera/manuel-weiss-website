/** Schematische SVG‑Visualisierungen (Präsentations‑Niveau, barrierearm). */

function SvgDefs() {
  return (
    <defs>
      <linearGradient id="cw-diag-accent" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stopColor="var(--cw-accent)" stopOpacity={0.35} />
        <stop offset="100%" stopColor="var(--cw-accent-strong)" stopOpacity={0.12} />
      </linearGradient>
    </defs>
  );
}

function SvgFramed({ title, children, vb = '0 0 480 160', height = '11rem', maxH = '15rem' }) {
  return (
    <svg
      role="img"
      aria-labelledby="cw-svg-title"
      viewBox={vb}
      width="480"
      height="160"
      className="cw-diagram-svg"
      style={{ minHeight: height, maxHeight: maxH }}
    >
      <title id="cw-svg-title">{title}</title>
      {children}
    </svg>
  );
}

function OrientFlow() {
  const steps = ['Check-in', 'Erarbeitung', 'Verdichtung', 'Commitment'];
  return (
    <SvgFramed title="Ablaufimpuls eines Workshop‑Blocks." vb="0 0 480 152" height="9.25rem">
      <SvgDefs />
      <path
        d="M36 94 H444"
        stroke="var(--cw-border)"
        strokeWidth="2"
        strokeLinecap="round"
      />
      {steps.map((label, i) => {
        const x = 60 + i * (360 / Math.max(steps.length - 1, 1));
        return (
          <g key={label}>
            <circle cx={x} cy="94" r="13" fill="var(--cw-card)" stroke="var(--cw-accent)" strokeWidth="2.5" />
            <circle cx={x} cy="94" r="4" fill="var(--cw-accent)" />
            <text
              x={x}
              y="130"
              textAnchor="middle"
              fill="var(--cw-text-muted)"
              style={{ font: 'bold 11px system-ui,sans-serif', letterSpacing: '0.04em' }}
            >
              {label}
            </text>
          </g>
        );
      })}
      <text
        x="240"
        y="38"
        textAnchor="middle"
        fill="var(--cw-text-secondary)"
        style={{ font: '600 14px system-ui,sans-serif' }}
      >
        Von persönlicher Anbindung zur gemeinsamen Entscheidungsreife
      </text>
    </SvgFramed>
  );
}


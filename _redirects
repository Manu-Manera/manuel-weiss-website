# URL-Rewrites (_redirects-Format)
# Wird nur ausgewertet, wenn der Host dieses Format unterstützt (nicht bei reinem S3).
# Hauptdeploy: S3 + CloudFront (siehe deploy-aws-website.sh).

# Admin & Management Routes
/admin              /admin.html           200
/admin-panel        /admin.html           200  
/user-management    /admin.html           200
/users              /admin.html           200
/analytics          /analytics-dashboard.html 200
/analytics-dashboard /analytics-dashboard.html 200

# Personality Development Routes
/persoenlichkeitsentwicklung /persoenlichkeitsentwicklung-uebersicht.html 200
/personality        /persoenlichkeitsentwicklung-uebersicht.html 200
/methods            /persoenlichkeitsentwicklung-uebersicht.html 200

# English Language Routes (/en/)
/en/persoenlichkeitsentwicklung-uebersicht.html    /en/persoenlichkeitsentwicklung-uebersicht.html  200
/en/persoenlichkeitsentwicklung.html               /en/persoenlichkeitsentwicklung.html            200
/en/ikigai.html                                    /en/ikigai.html                                200
/en/methods/*                                      /en/methods/:splat                             200
/en/*                                              /en/:splat                                    200

# Application Automation Routes
/applications       /applications/index.html      200
/bewerbung          /applications/index.html      200
/bewerbungen        /applications/index.html      200
/application        /applications/index.html      200

# API Documentation & OpenAPI
/api-docs           /api-documentation.html   200
/api-docs/          /api-documentation.html   200
/docs/api           /docs/api/openapi.yaml    200
/openapi.yaml       /docs/api/openapi.yaml    200
/swagger            /api-documentation.html   200

# PWA Routes
/manifest.json      /manifest.json     200
/sw.js             /sw.js             200
/service-worker.js /sw.js             200

# Health & Status Routes
/health             /health.html           200
/status             /health.html           200
/healthz            /health.html           200
/readyz             /health.html           200

# API: früher Netlify Functions — Produktion nutzt API Gateway (js/aws-app-config.js).
# Keine /.netlify/functions-Redirects mehr (S3/CloudFront würden sie ohnehin nicht ausführen).

# WICHTIG: Kein Catch-all Redirect für SPA!
# Das würde alle anderen Routen überschreiben
# Wenn nötig, nur für spezifische Apps:
# /app/*             /app/index.html           200
